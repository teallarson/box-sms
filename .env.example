# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Arcade MCP gateway ───────────────────────────────────────────────────────
# Create at: Arcade Dashboard → MCP Gateways → Create
#   Auth type: arcade_header
#   Allowlist: Google_Sheets.GetSpreadsheet, Google_Sheets.UpdateCells
ARCADE_API_KEY=arc_...
ARCADE_MCP_URL=https://api.arcade.dev/mcp/<your-gateway-slug>

# ── Google Sheet ─────────────────────────────────────────────────────────────
# Spreadsheet ID is the long string in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEET_ID=1aBcDeFgHi...
SHEET_TAB=Sheet1

# ── Twilio Sync ───────────────────────────────────────────────────────────────
# Twilio Console → Sync → Services → Create → name "box-sms" → copy the IS... SID
SYNC_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Allowlist ─────────────────────────────────────────────────────────────────
# Allowed sender phone number(s) in E.164 format, comma-separated.
ALLOWED_FROM=+15551234567,+15557654321
